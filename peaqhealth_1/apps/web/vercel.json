{
  "functions": {
    "app/api/labs/upload/route.ts": {
      "maxDuration": 60
    },
    "app/api/sync/nightly/route.ts": {
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/sync/nightly",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/weekly-snapshots",
      "schedule": "0 7 * * 1"
    }
  ]
}
